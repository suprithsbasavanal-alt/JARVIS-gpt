# General
ENV=development
SECRET_KEY=generate_random_key_here

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Databases & Caching
DATABASE_URL=postgresql://jarvis_user:jarvis_password@localhost:5432/jarvis_db
QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_URL=redis://localhost:6379/0

# Model Configuration
PLANNER_PRIMARY_MODEL=qwen2.5:7b
PLANNER_FALLBACK_MODEL=llama3.2:3b
EXECUTOR_PRIMARY_MODEL=llama3:8b
EXECUTOR_FALLBACK_MODEL=phi3:medium

# Audio Setup
WAKE_WORDS=jarvis,hey jarvis
